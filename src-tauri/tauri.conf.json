{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaude GUI",
  "version": "0.2.0",
  "identifier": "com.openclaude.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaude Desktop",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["msi"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
